# Environment template for local orchestration (docker compose).
# Copy to infrastructure/.env. Never commit real secrets.

# --- PostgreSQL ---
POSTGRES_USER=orca
POSTGRES_PASSWORD=orca
POSTGRES_DB=orca
POSTGRES_PORT=5432

# --- Neo4j ---
# NEO4J_AUTH is "user/password" for the official image.
NEO4J_AUTH=neo4j/please-change-me
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474

# --- Backend ---
BACKEND_PORT=8000
# Set to "postgres" to use the database backend (Phase 1); "memory" runs seeded.
ORCA_STORAGE_BACKEND=memory

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
