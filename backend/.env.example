# ORCA backend configuration (template).
# Copy to .env and adjust. Never commit a real .env.

# --- Application ---
ORCA_ENV=local
ORCA_DEBUG=true
ORCA_API_PREFIX=/api/v1

# --- Storage backend ---
# "memory" runs the skeleton without a database, using seeded sample data.
# "postgres" uses the PostgreSQL + Neo4j wiring (Phase 1+).
ORCA_STORAGE_BACKEND=memory

# Dev authentication: the user assumed when no X-ORCA-User header is supplied.
# Local/dev only — production replaces this with real authentication.
ORCA_DEV_DEFAULT_USER=admin

# Mirror entities/relationships into Neo4j (optional; PostgreSQL is authoritative).
ORCA_GRAPH_ENABLED=false

# --- PostgreSQL (system of record) ---
ORCA_POSTGRES_DSN=postgresql+psycopg://orca:orca@localhost:5432/orca

# --- Neo4j (relationship graph projection) ---
ORCA_NEO4J_URI=bolt://localhost:7687
ORCA_NEO4J_USER=neo4j
ORCA_NEO4J_PASSWORD=please-change-me

# --- Evidence object store ---
# Where evidence bytes are stored. Local path for the skeleton.
ORCA_EVIDENCE_STORE=./.evidence

# --- CORS ---
# Comma-separated origins permitted to call the API (the frontend dev server).
ORCA_CORS_ORIGINS=http://localhost:3000

# --- Analyst Copilot (v1.0) ---
# Local, propose-only AI assistance. Only the offline deterministic "mock" provider ships.
ORCA_AI_PROVIDER=mock

# --- Palantir Foundry connection (v1.1 spike; read-only, DISABLED by default) ---
# Leave disabled for local dev and CI — tests use a mock client and need no credentials.
# NEVER commit real values; copy this file to .env (gitignored) and fill in locally.
ORCA_FOUNDRY_ENABLED=false
# Tenant base URL, e.g. https://your-tenant.palantirfoundry.com
ORCA_FOUNDRY_TENANT_URL=
# Auth: provide EITHER a pre-issued bearer token, OR an OAuth2 client id + secret.
ORCA_FOUNDRY_TOKEN=
ORCA_FOUNDRY_CLIENT_ID=
ORCA_FOUNDRY_CLIENT_SECRET=
# Ontology + a single harmless demo object to read during a manual connection test.
ORCA_FOUNDRY_ONTOLOGY_API_NAME=
ORCA_FOUNDRY_TEST_OBJECT_TYPE=OrcaCase
ORCA_FOUNDRY_TEST_OBJECT_ID=
# Real client: "rest" (httpx REST connector, default) or "sdk" (placeholder).
ORCA_FOUNDRY_CLIENT=rest
# Optional OAuth2 scopes for the client-credentials grant (space-separated), e.g.
# "api:ontologies-read". Leave blank to use the client's default granted scopes.
ORCA_FOUNDRY_SCOPES=
# Optional: override the SDK module the "sdk" client probes for (default: foundry_sdk).
ORCA_FOUNDRY_SDK_MODULE=

# --- Hunting Grounds autonomous discovery (DISABLED by default) ---
# Lets ORCA *seek* new venues in an AOR and propose them into the registry. It can ONLY
# propose — an administrator still authorizes each source (with a lawful basis) before
# anything is monitored. It performs NO scraping and NO dark-web crawling; the http provider
# talks only to a source you are LICENSED to query. See docs/hunting_grounds_discovery.md.
#
# provider: "disabled" (default), "mock" (synthetic offline candidates), or "http" (real).
ORCA_HUNTING_DISCOVERY_PROVIDER=disabled
# For the http provider: the licensed discovery/OSINT endpoint (queried read-only with ?aor=).
ORCA_HUNTING_DISCOVERY_URL=
# Secret API key sent as a Bearer token (never logged). Leave blank if the endpoint needs none.
ORCA_HUNTING_DISCOVERY_API_KEY=
# REQUIRED to enable the http provider: a recorded lawful basis for querying that source.
ORCA_HUNTING_DISCOVERY_LAWFUL_BASIS=
# How to read the endpoint's JSON: dotted path to the results array, and the per-item fields.
ORCA_HUNTING_DISCOVERY_RESULTS_PATH=results
ORCA_HUNTING_DISCOVERY_NAME_FIELD=name
ORCA_HUNTING_DISCOVERY_URL_FIELD=url
# Default category applied to discovered candidates (escort_listing, classified, forum, ...).
ORCA_HUNTING_DISCOVERY_CATEGORY=escort_listing
# Dark-web (Tor) transport: a SOCKS proxy to reach .onion sources, e.g. socks5://127.0.0.1:9050.
# Requires `pip install ".[tor]"` (socksio). Using it requires the acknowledgment below, which
# records that legal counsel sign-off AND law-enforcement deconfliction are in place. Locate-only,
# text/metadata, CSAM-safe — same as every other source. Leave blank for clearnet-only.
ORCA_HUNTING_DISCOVERY_TOR_PROXY=
ORCA_HUNTING_DISCOVERY_DARKWEB_ACK=false
# Standing AOR watchlist a sweep covers when none is named explicitly (comma-separated), e.g.
# "Rhode Island,Connecticut,Massachusetts". Lets ORCA seek across the whole region in one pass.
ORCA_HUNTING_DISCOVERY_AORS=
# Continuous (scheduled) discovery — the autonomous cadence. DISABLED by default. When enabled,
# ORCA sweeps the watchlist on an interval on its own (still proposes only; admin authorizes
# each). An administrator can pause/resume the loop at runtime (kill-switch) without a redeploy.
ORCA_HUNTING_DISCOVERY_SCHEDULE_ENABLED=false
ORCA_HUNTING_DISCOVERY_SCHEDULE_INTERVAL_MINUTES=60
ORCA_HUNTING_DISCOVERY_SCHEDULE_LIMIT=10

# --- Hunting Grounds automated collection (DISABLED by default) ---
# Pulls TEXT-ONLY candidate leads from MONITORED sources and proposes each as an observation in
# the review queue (analysts decide). CSAM-safe by construction: a lead carries text + entity
# hints only — there is NO media field, and the http provider reads only text. No scraping, no
# dark-web; the http provider talks only to a source you are LICENSED to query. On the cadence,
# collection runs each tick after the discovery sweep. See docs/hunting_grounds_collection.md.
#
# provider: "disabled" (default), "mock" (synthetic offline leads), or "http" (real).
ORCA_HUNTING_COLLECTION_PROVIDER=disabled
# For the http provider: the licensed endpoint (queried read-only with ?source=&aor=&limit=).
ORCA_HUNTING_COLLECTION_URL=
# Secret API key sent as a Bearer token (never logged). Leave blank if the endpoint needs none.
ORCA_HUNTING_COLLECTION_API_KEY=
# REQUIRED to enable the http provider: a recorded lawful basis for querying that source.
ORCA_HUNTING_COLLECTION_LAWFUL_BASIS=
# How to read the endpoint's JSON: dotted path to the results array, and the per-item TEXT fields.
ORCA_HUNTING_COLLECTION_RESULTS_PATH=results
ORCA_HUNTING_COLLECTION_SUMMARY_FIELD=summary
ORCA_HUNTING_COLLECTION_OBSERVED_AT_FIELD=observed_at
ORCA_HUNTING_COLLECTION_ENTITIES_FIELD=entities
ORCA_HUNTING_COLLECTION_DEFAULT_CONFIDENCE=0.4
# Dark-web (Tor) transport for collection — same gate as discovery. A SOCKS proxy to reach .onion
# sources (requires `pip install ".[tor]"`), and the acknowledgment that counsel sign-off + LE
# deconfliction are in place. Locate-only, text/metadata, CSAM-safe. Leave blank for clearnet-only.
ORCA_HUNTING_COLLECTION_TOR_PROXY=
ORCA_HUNTING_COLLECTION_DARKWEB_ACK=false
