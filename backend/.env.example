# ORCA backend configuration (template).
# Copy to .env and adjust. Never commit a real .env.

# --- Application ---
ORCA_ENV=local
ORCA_DEBUG=true
ORCA_API_PREFIX=/api/v1

# --- Storage backend ---
# "memory" runs the skeleton without a database, using seeded sample data.
# "postgres" uses the PostgreSQL + Neo4j wiring (Phase 1+).
ORCA_STORAGE_BACKEND=memory

# Dev authentication: the user assumed when no X-ORCA-User header is supplied.
# Local/dev only — production replaces this with real authentication.
ORCA_DEV_DEFAULT_USER=admin

# Mirror entities/relationships into Neo4j (optional; PostgreSQL is authoritative).
ORCA_GRAPH_ENABLED=false

# --- PostgreSQL (system of record) ---
ORCA_POSTGRES_DSN=postgresql+psycopg://orca:orca@localhost:5432/orca

# --- Neo4j (relationship graph projection) ---
ORCA_NEO4J_URI=bolt://localhost:7687
ORCA_NEO4J_USER=neo4j
ORCA_NEO4J_PASSWORD=please-change-me

# --- Evidence object store ---
# Where evidence bytes are stored. Local path for the skeleton.
ORCA_EVIDENCE_STORE=./.evidence

# --- CORS ---
# Comma-separated origins permitted to call the API (the frontend dev server).
ORCA_CORS_ORIGINS=http://localhost:3000

# --- Analyst Copilot (v1.0) ---
# Local, propose-only AI assistance. Only the offline deterministic "mock" provider ships.
ORCA_AI_PROVIDER=mock

# --- Palantir Foundry connection (v1.1 spike; read-only, DISABLED by default) ---
# Leave disabled for local dev and CI — tests use a mock client and need no credentials.
# NEVER commit real values; copy this file to .env (gitignored) and fill in locally.
ORCA_FOUNDRY_ENABLED=false
# Tenant base URL, e.g. https://your-tenant.palantirfoundry.com
ORCA_FOUNDRY_TENANT_URL=
# Auth: provide EITHER a pre-issued bearer token, OR an OAuth2 client id + secret.
ORCA_FOUNDRY_TOKEN=
ORCA_FOUNDRY_CLIENT_ID=
ORCA_FOUNDRY_CLIENT_SECRET=
# Ontology + a single harmless demo object to read during a manual connection test.
ORCA_FOUNDRY_ONTOLOGY_API_NAME=
ORCA_FOUNDRY_TEST_OBJECT_TYPE=OrcaCase
ORCA_FOUNDRY_TEST_OBJECT_ID=
# Optional: override the SDK module the real client probes for (default: foundry_sdk).
ORCA_FOUNDRY_SDK_MODULE=
